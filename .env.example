# PulseNet — environment variables template.
# Copy this to .env and fill in your keys.

# --- Database (Prisma/SQLite — relative path, works on any machine) ---
DATABASE_URL="file:../db/custom.db"

# --- Gemini API keys (REQUIRED for the Python engine) ---
# Get both from: https://aistudio.google.com → "Get API key"
# Use two separate Google accounts/projects to double your RPM budget.
GEMINI_API_KEY_A="your_gemini_key_a_here"
GEMINI_API_KEY_B="your_gemini_key_b_here"

# Gemini model to use (default: gemini-2.5-flash — best free-tier balance)
GEMINI_MODEL="gemini-2.5-flash"

# --- Python FastAPI engine URL ---
# Default: localhost for local development
PULSENET_ENGINE_URL="http://localhost:8000"

# --- Optional: web search in TS fallback mode ---
# Only needed if the Python engine is offline AND you want news-search.
# Serper.dev free: https://serper.dev (sign up, copy API key)
SEARCH_API_KEY=""

# --- Optional: ACLED conflict feed ---
# Free academic/NGO registration: https://acleddata.com/access
# Engine is env-gated — stays dark until both keys are provided.
ACLED_KEY=""
ACLED_EMAIL=""
